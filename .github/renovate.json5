{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
  ],
  "baseBranchPatterns": ["testing"],
  "branchPrefix": "renovate/",
  "schedule": ["* 0-3 * * 1"],
  "enabledManagers": ["github-actions", "custom.regex"],

  // Do not rebase when the default branch is updated
  "rebaseWhen": "never",

  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^Containerfile$/"],
      matchStrings: [
        "COPY --from=(?<depName>ghcr\\.io/ublue-os/bluefin-wallpapers-gnome):(?<currentValue>[^@]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "docker"
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^system_files/bluefin/usr/share/ublue-os/just/60-bonedigger\\.just$/"],
      matchStrings: [
        "BONEDIGGER_VERSION\\s*:=\\s*\"(?<currentValue>v?[0-9.]+)\""
      ],
      datasourceTemplate: "github-releases",
      depNameTemplate: "projectbluefin/bonedigger"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchDepTypes": ["action"],
      "pinDigests": true
    },
    {
      "description": "Never SHA-pin projectbluefin/testsuite refs — use @v1 managed tag",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["projectbluefin/testsuite"],
      "enabled": false
    },
    {
      "automerge": true,
      "matchManagers": ["github-actions"],
      "matchDepTypes": ["action"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}

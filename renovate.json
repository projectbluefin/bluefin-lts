{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>projectbluefin/renovate-config"
  ],
  "baseBranchPatterns": ["testing"],
  "packageRules": [
    {
      "description": "Automerge digest/pin/patch/minor for all dependencies",
      "matchUpdateTypes": ["digest", "pin", "patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Never SHA-pin projectbluefin/ refs — use @v1/@main managed tags; SHA pins break the no-sha-pins-for-internal-actions pre-commit hook and block automerge",
      "matchManagers": ["github-actions"],
      "matchDepNames": ["/^projectbluefin\//"],
      "pinDigests": false,
      "enabled": false
    }
  ]
}
